# Application
APP_NAME=SecurePDFMerger
APP_ENV=development
DEBUG=true
SECRET_KEY=a6ee0a16d718f369e3983eecff5f153a0def78ebed94711b055802b8fd5699cc
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://pdfuser:pdfpass@db:5432/pdfmerger
DATABASE_URL_SYNC=postgresql://pdfuser:pdfpass@db:5432/pdfmerger

# For development with SQLite:
# DATABASE_URL=sqlite+aiosqlite:///./app.db
# DATABASE_URL_SYNC=sqlite:///./app.db

# JWT
JWT_SECRET_KEY=a6ee0a16d718f369e3983eecff5f153a0def78ebed94711b055802b8fd5699cc
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# File Upload
MAX_FILE_SIZE_MB=50
MAX_FILES_PER_MERGE=20
UPLOAD_DIR=./temp_uploads
MERGED_DIR=./temp_merged
FILE_RETENTION_MINUTES=30

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_MERGE_PER_HOUR=10

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Redis (for rate limiting in production)
REDIS_URL=redis://redis:6379/0

# Watermark
DEFAULT_WATERMARK_TEXT=SecurePDFMerger
WATERMARK_FONT_SIZE=36
WATERMARK_OPACITY=0.1